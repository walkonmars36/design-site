---
import HeroBtn from "../components/HeroBtn.astro";
---

<section>
  <div class="hero wrapper-np">
    <div class="hero__content">
      <span>Hi, I’m Mark Lawson</span>
      <h1>Your digital partner</h1>
      <p>
        Helping purpose driven professionals get more from their online
        presence, from strategy and messaging through to the build and the tools
        that support it.
      </p>
      <HeroBtn />
    </div>
    <div class="hero__image-wrap">
      <img
        src="/assets/images/mark-bk-800.avif"
        alt="Bristol based web designer and developer Mark Lawson"
        loading="eager"
        width="800"
        height="1000"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: var(--space-m);
    align-items: stretch;
    overflow: hidden;
  }

  .hero__content {
    padding: var(--fluid-18-80);
    padding-right: 0;
    align-self: center;
  }
  .hero__image-wrap {
    aspect-ratio: 4/5;
    width: 100%;
    justify-self: end;
  }

  img {
    width: 100%;
    height: 100%;
  }
  /* //////////////////////////////// */

  h1 {
    margin: 0.5rem 0;
    padding-right: 0.5em;
  }
  h1 span {
    color: #bbbcbf;
  }
  .typewriter {
    margin-left: 0;
  }

  section * {
    color: var(--color-white);
  }

  section {
    margin-top: 6rem;
  }

  div {
    background: var(--color-secondary-200);
  }
</style>
