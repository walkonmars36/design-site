---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient } from "../../sanity/client";
import { createDataAttribute } from "@sanity/visual-editing";

const { id } = Astro.params;

const project = await sanityClient.fetch(
  `*[_type == "project" && slug.current == $id][0] {
    "docId": _id,
    title,
    heading,
    url,
    services,
    objective,
    process,
    result,
    "heroImage": heroImage.asset->url,
    "altHero": heroImage.alt,
  }`,
  { id }
);

if (!project) return Astro.redirect("/404");

const { docId, title, heading, heroImage, url, services, objective, process, altHero, result } = project;

const attr = (path: string) =>
  createDataAttribute({ id: docId, type: "project", path }).toString();

const pageTitle = `${title} | Project detail`;
const description = `Project detail for ${title}`;
---

<BaseLayout pageTitle={pageTitle} description={description}>
  <article>
    <h1 class="wrapper" data-sanity={attr("title")}>Project detail: <br />{title}</h1>
    <section class="wrapper">
      {heroImage && <img src={heroImage} alt={altHero} />}
      <div class="project-detail__info flex space-xl">
        <div>
          <span class="project-info title-small">Project info</span>
        </div>
        <div>
          <div class="project-detail-content">
            <h2 class="project-detail__h2" data-sanity={attr("heading")}>{heading}</h2>
            <div class="project-detail__url flex">
              <span class="title-small">Client site:</span>
              <a href={url} target="_blank">{url}</a>
            </div>
          </div>
        </div>
      </div>
      <div class="project-detail__info flex space-xl">
        <h3 class="services-h3 title-small self-start">Services</h3>
        <div class="project-detail__services">
          <ul>
            {services.map((service) => <li>{service}</li>)}
          </ul>
        </div>
      </div>
      <div class="project-detail__info-b flex">
        <div class="flow">
          <h3>Objective</h3>
          <p data-sanity={attr("objective")}>{objective}</p>
        </div>
        <div class="flow">
          <h3>Process</h3>
          <p data-sanity={attr("process")}>{process}</p>
        </div>
        <div class="flow">
          <h3>Result</h3>
          <p data-sanity={attr("result")}>{result}</p>
        </div>
      </div>
    </section>

    <style>
      article {
        margin-top: 6rem;
      }
      h1 {
        padding: var(--space-s-m) var(--fluid-18-80);
        background: var(--color-secondary-200);
        color: var(--color-white);
        border-radius: var(--border-radius-xxl);
      }

      h2 {
        font-family: var(--ff-body);
        font-weight: 400;
        padding-bottom: 0;
      }
      section {
        margin-top: var(--space-l);
        background: var(--color-bg-light);
        border-radius: var(--border-radius-xxl);
      }
      img {
        width: 100%;
        border-radius: var(--border-radius-md);
      }

      .project-detail__info {
        flex-direction: column;
        --gap: 0;
      }

      a {
        transition: font-weight 0.2s;
      }

      a:hover {
        font-weight: 700;
      }

      .project-detail__info-b {
        flex-direction: column;
        --gap: var(--space-xl-2xl);
        margin-top: var(--space-2xl-3xl);
      }

      .flow {
        --flow-space: var(--space-xs);
      }

      .project-detail__url {
        flex-direction: column;
        --gap: 0;
        margin-top: var(--space-m-l);
      }

      .project-detail__services li {
        border-bottom: 1px solid var(--color-accent-400);
      }

      .project-detail__services li {
        padding-top: var(--space-l);
      }

      .project-info {
        margin-bottom: var(--space-s);
      }

      .title-small {
        margin-top: var(--space-3xs);
      }

      @media (min-width: 768px) {
        .project-detail__url {
          flex-direction: row;
          --gap: 0.5em;
        }

        .project-detail__url a {
          padding-top: 0.15em;
        }
      }

      @media (min-width: 992px) {
        .project-detail__info {
          display: grid;
          grid-template-columns: 0.5fr 1fr;
        }

        .project-detail__services li:first-child {
          padding-top: 0;
        }
      }
    </style>
  </article>
</BaseLayout>
